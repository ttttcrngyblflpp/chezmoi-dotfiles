# This file has been auto-generated by i3-config-wizard(1).
# It will not be overwritten, so edit it as you like.
#
# Should you change your keyboard layout some time, delete
# this file and re-run i3-config-wizard(1).
#

{{- if eq .chezmoi.hostname "gongt-glaptop2" }}
exec aw-qt

bindsym $gui+Home exec wm k d
bindsym $gui+End exec wm k q

bindsym $gui+Shift+$alt+w exec wm w
{{- end }}

# bindings for attaching to/detaching from an external monitor
{{- if eq .chezmoi.hostname "gongt-glaptop2" }}
bindsym $gui+Shift+a exec wm a
bindsym $gui+$alt+a exec i3-msg '[workspace=".*"] move workspace to output primary'
bindsym $gui+Shift+$alt+d exec wm d
{{- else }}
bindsym $gui+Shift+a exec xrandr --output DP-4 --mode 5120x1440 --rate 240 --primary --output DP-2 --off
bindsym $gui+$alt+a exec xrandr --output DP-2 --mode 5120x1440 --rate 240 --primary --output DP-4 --off
{{- end }}

# start a browser
{{- if eq .chezmoi.hostname "gongt-glaptop2" }}
bindsym $gui+Tab exec google-chrome
{{- else }}
bindsym $gui+Tab exec google-chrome-stable
{{- end }}

bindsym $gui+Shift+o exec alacritty -e pulsemixer, exec easyeffects, exec alacritty --title terminal
bindsym $gui+$alt+o exec wm o
bindsym $gui+o exec wm m

bindsym $gui+$alt+s exec systemctl suspend

bindsym $gui+Shift+m exec i3-input -F 'mark %s' -l 1 -P 'Mark: '
bindsym $gui+m exec i3-input -F '[con_mark="%s"] focus' -l 1 -P 'Goto: '
bindsym $gui+$alt+m exec wm mo
exec wm mo

bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +2% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -2% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status
bindsym XF86AudioNext exec --no-startup-id playerctl next
bindsym XF86AudioPrev exec --no-startup-id playerctl previous
bindsym XF86AudioStop exec --no-startup-id playerctl play-pause

bindsym $gui+semicolon exec i3-input -F "exec i3-msg %s" -P 'i3-msg '

bindsym $gui+b focus output down
bindsym $gui+Shift+b move to output down
bindsym $gui+Shift+$alt+b move workspace to output down

# resize window
bindsym $gui+Right exec i3ext resize --direction right --percentage 1
bindsym $gui+Shift+Right exec i3ext swap right
bindsym $gui+$alt+Right exec i3-input -F 'exec i3ext resize --direction right --percentage %s' -P 'resize right: '
bindsym $gui+Up exec i3ext resize --direction right --percentage "-1"
bindsym $gui+Left exec i3ext resize --direction left --percentage 1
bindsym $gui+Shift+Left exec i3ext swap left
bindsym $gui+$alt+Left exec i3-input -F 'exec i3ext resize --direction left --percentage %s' -P 'resize left: '
bindsym $gui+Down exec i3ext resize --direction left --percentage "-1"

# resize toplevel containers
bindsym $gui+c exec i3ext center
bindsym $gui+r exec i3ext center right
bindsym $gui+g exec i3ext center left
bindsym $gui+z exec i3-input -F "exec i3ext resize-all %s" -P 'i3ext resize-all '
bindsym $gui+Shift+z exec i3-input -F "exec i3-msg [floating] resize set %s" -P 'i3-msg [floating] resize set '

# Rename current window
bindsym $gui+n exec i3-input -F "title_format %s"

# Rename current workspace
bindsym $gui+Shift+n exec NUM=$(i3-msg -t get_workspaces | jq -r '.[] | select(.focused==true).name' | cut -d':' -f1) && i3-input -F "rename workspace to $NUM:%s"

# Take screenshot and copy to clipboard
bindsym --release $gui+Delete exec --no-startup-id wm s
bindsym --release $gui+Shift+Delete exec --no-startup-id wm s s

# start a terminal
bindsym $gui+grave exec alacritty
bindsym $gui+Shift+grave [workspace="__focused__"] split vertical; [workspace="__focused__"] layout stacking

# start a placeholder
bindsym $gui+Prior open

# change focus
bindsym $gui+comma focus left
bindsym $gui+j focus down
bindsym $gui+k focus up
bindsym $gui+period focus right

# move focused window
bindsym $gui+Shift+comma move left
bindsym $gui+Shift+j move down
bindsym $gui+Shift+k move up
bindsym $gui+Shift+period move right

bindsym $gui+d scratchpad show
bindsym $gui+Shift+d move scratchpad

# Disable window titlebars always
default_border pixel 1

# Set a gaps of 10 (outer gaps is unset because it's added to this)
gaps inner 10

# class                 border  backgr. text    indicator child_border
client.focused          #f58b54 #f58b54 #ffffff #ffffff   #f58b54

# i3 config file (v4)
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!

set $gui Mod4
set $alt Mod1

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:monospace 10

# This font is widely installed, provides lots of unicode glyphs, right-to-left
# text rendering and scalability on retina/hidpi displays (thanks to pango).
#font pango:DejaVu Sans Mono 8

# Before i3 v4.8, we used to recommend this one as the default:
# font -misc-fixed-medium-r-normal--13-120-75-75-C-70-iso10646-1
# The font above is very space-efficient, that is, it looks good, sharp and
# clear in small sizes. However, its unicode glyph coverage is limited, the old
# X core fonts rendering does not support right-to-left and this being a bitmap
# font, it doesn’t scale on retina/hidpi displays.

# Use Mouse+$gui to drag floating windows to their wanted position
floating_modifier $gui

bindsym $gui+equal focus mode_toggle
bindsym $gui+Shift+equal floating toggle

# kill focused window
bindsym $gui+Shift+w kill

# start dmenu (a program launcher)
bindsym $gui+minus exec dmenu_run
# There also is the (new) i3-dmenu-desktop which only displays applications
# shipping a .desktop file. It is a wrapper around dmenu, so you need that
# installed.
# bindsym $gui+d exec --no-startup-id i3-dmenu-desktop

# enter fullscreen mode for the focused container
bindsym $gui+f fullscreen toggle

# Define the mode name
set $mode_layout Layout (h) horizontal, (v) vertical, (s) stacking, (t) tabbed

mode "$mode_layout" {
    # change container layout (stacked, tabbed, toggle split)
    bindsym s layout stacking; mode "default"
    bindsym Shift+s split vertical; layout stacking; mode "default"
    bindsym t layout tabbed; mode "default"
    bindsym Shift+t split horizontal; layout tabbed; mode "default"

    bindsym h layout splith; mode "default"
    bindsym Shift+h split horizontal; mode "default"
    bindsym v layout splitv; mode "default"
    bindsym Shift+v split vertical; mode "default"


    # Back to normal: Enter or Escape
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

# Bind a "hard to hit" key to enter the mode
bindsym $gui+Shift+l mode "$mode_layout"

# focus the parent container
bindsym $gui+a focus parent

# focus the child container
bindsym $gui+i focus child

# switch to workspace
bindsym $gui+1 workspace number 1
bindsym $gui+2 workspace number 2
bindsym $gui+3 workspace number 3
bindsym $gui+4 workspace number 4
bindsym $gui+5 workspace number 5
bindsym $gui+6 workspace number 6
bindsym $gui+7 workspace number 7
bindsym $gui+8 workspace number 8
bindsym $gui+9 workspace number 9
bindsym $gui+0 workspace number 0
bindsym $gui+$alt+1 workspace number 11
bindsym $gui+$alt+2 workspace number 12
bindsym $gui+$alt+3 workspace number 13
bindsym $gui+$alt+4 workspace number 14
bindsym $gui+$alt+5 workspace number 15
bindsym $gui+$alt+6 workspace number 16
bindsym $gui+$alt+7 workspace number 17
bindsym $gui+$alt+8 workspace number 18
bindsym $gui+$alt+9 workspace number 19
bindsym $gui+$alt+0 workspace number 20

# move focused container to workspace
bindsym $gui+Shift+1 move container to workspace number 1
bindsym $gui+Shift+2 move container to workspace number 2
bindsym $gui+Shift+3 move container to workspace number 3
bindsym $gui+Shift+4 move container to workspace number 4
bindsym $gui+Shift+5 move container to workspace number 5
bindsym $gui+Shift+6 move container to workspace number 6
bindsym $gui+Shift+7 move container to workspace number 7
bindsym $gui+Shift+8 move container to workspace number 8
bindsym $gui+Shift+9 move container to workspace number 9
bindsym $gui+Shift+0 move container to workspace number 0
bindsym $gui+Shift+$alt+1 move container to workspace number 11
bindsym $gui+Shift+$alt+2 move container to workspace number 12
bindsym $gui+Shift+$alt+3 move container to workspace number 13
bindsym $gui+Shift+$alt+4 move container to workspace number 14
bindsym $gui+Shift+$alt+5 move container to workspace number 15
bindsym $gui+Shift+$alt+6 move container to workspace number 16
bindsym $gui+Shift+$alt+7 move container to workspace number 17
bindsym $gui+Shift+$alt+8 move container to workspace number 18
bindsym $gui+Shift+$alt+9 move container to workspace number 19
bindsym $gui+Shift+$alt+0 move container to workspace number 20

# reload the configuration file
bindsym $gui+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $gui+Shift+r restart
# exit i3 (logs you out of your X session)

# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available)
bar {
	position top
        status_command i3status
	tray_output primary
}
