#!/bin/bash

SESSION="$(basename "$PWD")""$1"

if tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "tmux session already exists, attach instead"
    exit 0
fi

if grep "^$SESSION$" <(kak -l); then
    echo "kak session already exists, close it first"
    exit 0
fi


tmux new-session -d -s "$SESSION" -n a
tmux new-window -d -t "$SESSION": -n b
tmux new-window -d -t "$SESSION": -n c
tmux new-window -d -t "$SESSION": -n d
tmux new-window -d -t "$SESSION": -n e
tmux new-window -d -t "$SESSION": -n f
tmux new-window -d -t "$SESSION": -n run
tmux new-window -d -t "$SESSION": -n log
tmux new-window -d -t "$SESSION": -n vcs
tmux new-window -d -t "$SESSION": -n misc

tmux send-keys -t "$SESSION:a" "kak -s $SESSION -e 'rename-client a'" Enter
tmux send-keys -t "$SESSION:b" "kak -c $SESSION -e 'rename-client b'" Enter
tmux send-keys -t "$SESSION:c" "kak -c $SESSION -e 'rename-client c'" Enter
tmux send-keys -t "$SESSION:d" "kak -c $SESSION -e 'rename-client d'" Enter
tmux send-keys -t "$SESSION:e" "kak -c $SESSION -e 'rename-client e'" Enter
tmux send-keys -t "$SESSION:f" "kak -c $SESSION -e 'rename-client f'" Enter

tmux attach -t "$SESSION"
