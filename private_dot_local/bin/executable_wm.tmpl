#!/bin/bash

set -x

apply_mouse_settings() {
    local device_name="$1"
    local angle="$2"
    local accel="0"

    # Calculate transformation matrix components
    local deg=$(bc -l <<<"$angle*4*a(1)/180")
    local cos=$(bc -l <<<"c($deg)")
    local sin=$(bc -l <<<"s($deg)")
    local negsin=$(bc -l <<<"-s($deg)")

    # Apply settings
    xinput set-prop "pointer:$device_name" "libinput Accel Speed" "$accel"
    xinput set-prop "pointer:$device_name" "Coordinate Transformation Matrix" \
        $cos $negsin 0 $sin $cos 0 0 0 1
}

case "$1" in
{{- if eq .chezmoi.hostname "gongt-glaptop2" }}
    "k")
        case "$2" in
            "d")
                setxkbmap -device $(xinput list --id-only 'AT Translated Set 2 keyboard') -option ctrl:s
apcaps -option altwin:swap_lalt_lwin -layout us -variant dvorak
                ;;
            "q")
                setxkbmap -device $(xinput list --id-only 'AT Translated Set 2 keyboard') -layout us -va
iant "" -option
                ;;
        esac
        ;;
    "a")
        case "$2" in
            "w")
                xrandr --output DP-2-8 --auto --primary --output DP-2-1 --right-of DP-2-8 --auto --outpu
 eDP-1 --mode 2560x1600 --below DP-2-1
                # Note that the positioning must be a separate command otherwise it doesn't work half th
 time.
                xrandr --setmonitor big auto DP-2-8,DP-2-1
                xrandr --output eDP-1 --pos 1280x1440
                ;;
            "b")
                xrandr --output DP-2 --mode 3840x1600 --primary --output eDP-1 --mode 2560x1600 --below
P-2
                ;;
            "")
                xrandr --output DP-2 --mode 5120x1440 --primary --output eDP-1 --mode 2560x1600 --below
P-2
                xrandr --output eDP-1 --pos 1280x1440
                ;;
        esac
        sleep 1
        xrdb -merge <.Xresources
        ;;
    "d")
        case "$2" in
            "w")
                xrandr --output DP-2-8 --off --output DP-2-1 --off --output eDP-1 --mode 2560x1600 --pri
ary
                xrandr --delmonitor big
                ;;
            "")
                xrandr --output DP-1 --off --output DP-2 --off --output DP-3 --off --output DP-4 --off -
output HDMI-1 --off --output eDP-1 --auto --mode 2560x1600 --primary
                ;;
        esac
        sleep 1
        xrdb -merge <.Xresources
        ;;
{{- end }}
{{- if eq .chezmoi.hostname "gongt-glaptop2" }}
    "o")
        i3-msg 'exec google-chrome --new-window calendar.google.com;
        exec google-chrome --new-window https://mail.google.com/chat/u/0/#chat/home;
        exec obsidian'
        ;;
    "m")
        i3-msg '[title="pulsemixer"] mark a
        [title="Calendar"] mark c
        [title="Easy Effects"] mark e
        [title="Chat"] mark h
        [title="obsidian"] mark o
        [title="terminal"] mark s
        [con_mark="."] move scratchpad'
        ;;
{{- else }}
    "o")
        i3-msg 'exec google-chrome-stable --new-window 1password.com;
        exec google-chrome-stable --new-window calendar.google.com;
        exec google-chrome-stable --new-window gmail.com;
        exec google-chrome-stable --new-window todoist.com;
        exec google-chrome-stable --new-window music.youtube.com;
        exec google-chrome-stable --new-window;
        exec obsidian'
        ;;
    "m")
        i3-msg '[title="pulsemixer"] mark a
        [title="New Tab"] mark b
        [title="Calendar"] mark c
        [title="Easy Effects"] mark e
        [title="Gmail"] mark m
        [title="obsidian"] mark o
        [title="terminal"] mark s
        [title="Todoist"] mark t
        [title="Music"] mark y
        [title="1Password"] mark 1
        [con_mark="."] move scratchpad'
        ;;
{{- end }}
    "mo")
        # Apply to Logitech
        apply_mouse_settings "Logitech USB Receiver" -9

        # Apply to Endgame Gear
        apply_mouse_settings "Endgame Gear Endgame Gear OP1 8k v2 Gaming Mouse" -12

        apply_mouse_settings "WL WLMOUSE 1K RECEIVER" -12
        ;;
    "s")
        case "$2" in
        "s")
            import png:- | xclip -selection clipboard -t image/png
        ;;
        "")
            import -window $(xdotool getactivewindow) png:- | xclip -selection clipboard -t image/png
        ;;
        esac
    ;;
esac
